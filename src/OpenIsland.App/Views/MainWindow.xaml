<Window x:Class="OpenIsland.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenIsland.App"
        mc:Ignorable="d"
        Title="Open Island - Control Center"
        Icon="pack://application:,,,/OpenIsland;component/Assets/face.png"
        Height="640"
        Width="940"
        MinHeight="420"
        MinWidth="640"
        Background="#1C1C1E"
        Foreground="#F2F2F7"
        FontFamily="Segoe UI Variable, Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:StringToBrushConverter x:Key="StringToBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- ============================================================
             Apple 风扁平化色板 + 控件样式。所有 Button/TextBox/ScrollBar
             用一致的圆角、低对比、subtle hover —— 不要 Windows 默认的厚
             border/raise 效果。
             ============================================================ -->

        <!-- Ghost Button：透明底，hover 时叠半透明白浮起 -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#E5E5EA"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A2C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tinted Button（用作"跳转"主操作）：低饱和蓝填充，hover 略亮 -->
        <Style x:Key="TintedButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 软风格 TextBox：仿 macOS 搜索框 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#F2F2F7"/>
            <Setter Property="CaretBrush" Value="#F2F2F7"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          BorderThickness="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 扁平 ScrollBar（同岛风格）：仅露细灰 thumb，无滑道无箭头 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#48484A"
                                                        CornerRadius="3"
                                                        Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 计数 Pill 徽章 -->
        <Style x:Key="CountPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- 会话卡片 DataTemplate -->
        <DataTemplate x:Key="SessionItemTemplate">
            <Border Background="#2C2C2E"
                    CornerRadius="12"
                    Padding="16,14"
                    Margin="0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 会话信息（原圆形工具图标已移除，仅保留标题前一个小状态点） -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0"
                                     Fill="{Binding StatusColor, Converter={StaticResource StringToBrushConverter}}"/>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F2F2F7"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Summary}"
                                   FontSize="12"
                                   Foreground="#98989D"
                                   Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="{Binding PhaseText}"
                                       FontSize="11"
                                       Foreground="#6C6C70"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding TokenInfo}"
                                       Visibility="{Binding HasTokenInfo, Converter={StaticResource BoolToVisibilityConverter}}"
                                       FontSize="11"
                                       Foreground="#6C6C70"
                                       Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding CostInfo}"
                                       Visibility="{Binding HasTokenInfo, Converter={StaticResource BoolToVisibilityConverter}}"
                                       FontSize="11"
                                       Foreground="#6C6C70"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 操作按钮（权限按钮 ghost-style，跳转用 tinted）-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <Button Content="1. Yes"
                                Visibility="{Binding ShowApproveButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding ApprovePermissionCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="#30D158"
                                Margin="0,0,4,0"/>
                        <Button Content="3. No"
                                Visibility="{Binding ShowApproveButton, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding DenyPermissionCommand}"
                                Style="{StaticResource GhostButton}"
                                Foreground="#FF453A"
                                Margin="0,0,8,0"/>
                        <Button Content="跳转"
                                Command="{Binding JumpToTerminalCommand}"
                                Style="{StaticResource TintedButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部 Hero：合并旧 "标题栏" 跟 "工具栏"，整块跟 Window 同色，去掉那条
             #2D2D2D 横条带来的"Windows 应用"感 -->
        <Grid Grid.Row="0" Margin="24,20,24,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Open Island"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#F2F2F7"/>
                <TextBlock Text="AI Agent Dashboard"
                           FontSize="12"
                           Foreground="#8E8E93"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Border Style="{StaticResource CountPill}" Background="#1F3A28">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#30D158"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding RunningCount, StringFormat='运行中 {0}'}"
                                   Foreground="#A7E5BD" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CountPill}"
                        Background="#3A2118"
                        Visibility="{Binding HasAttention, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#FF9F0A"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding AttentionCount, StringFormat='需关注 {0}'}"
                                   Foreground="#FFCC8A" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CountPill}" Background="#2C2C2E" Margin="4,0,0,0"
                        ToolTip="桥接连接状态">
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding IsBridgeConnected, Converter={StaticResource BoolToBrushConverter}}"
                             VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Tab 栏 + 时间窗口 pill -->
        <Grid Grid.Row="1" Margin="24,12,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Sessions" Command="{Binding SelectTabCommand}" CommandParameter="sessions">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTabSessions}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                    <Setter Property="Foreground" Value="#F2F2F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Overview" Command="{Binding SelectTabCommand}" CommandParameter="overview">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTabOverview}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                    <Setter Property="Foreground" Value="#F2F2F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Models" Command="{Binding SelectTabCommand}" CommandParameter="models">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTabModels}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                    <Setter Property="Foreground" Value="#F2F2F7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 时间窗口 pill 仅 Overview/Models 显示 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        Visibility="{Binding IsTabSessions, Converter={StaticResource InverseBoolToVis}}">
                <Button Content="All" Command="{Binding SelectRangeCommand}" CommandParameter="all">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRangeAll}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="30d" Command="{Binding SelectRangeCommand}" CommandParameter="30d">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRange30d}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="7d" Command="{Binding SelectRangeCommand}" CommandParameter="7d">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="10,4"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRange7d}" Value="True">
                                    <Setter Property="Background" Value="#2C2C2E"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 内容区：三 tab 互斥 -->
        <Grid Grid.Row="2">
            <!-- ============ Sessions tab ============ -->
            <Grid Visibility="{Binding IsTabSessions, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="24,0,24,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             MaxWidth="320"
                             HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="刷新" Command="{Binding RefreshCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Content="清理已完成" Command="{Binding ClearCompletedCommand}"
                                Style="{StaticResource GhostButton}"/>
                        <Button Content="设置" Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource GhostButton}"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Sessions}"
                                  ItemTemplate="{StaticResource SessionItemTemplate}"
                                  Margin="20,4,20,16"/>
                </ScrollViewer>
            </Grid>

            <!-- ============ Overview tab ============ -->
            <ScrollViewer Visibility="{Binding IsTabOverview, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,4,24,16" DataContext="{Binding DashboardStats}">
                    <!-- 第一排 4 卡：Sessions / Total tokens / Active days / Current streak -->
                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Sessions" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock Text="{Binding SessionsCount}"
                                           FontSize="22" FontWeight="Bold" Foreground="#F2F2F7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Total tokens" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock Text="{Binding TotalTokens, Converter={StaticResource HumanNum}}"
                                           FontSize="22" FontWeight="Bold" Foreground="#F2F2F7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Active days" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock Text="{Binding ActiveDays}"
                                           FontSize="22" FontWeight="Bold" Foreground="#F2F2F7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="Current streak" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F2F2F7" Margin="0,4,0,0">
                                    <Run Text="{Binding CurrentStreak, Mode=OneWay}"/><Run Text="d"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- 第二排 4 卡：Longest streak / Peak hour / Favorite model -->
                    <UniformGrid Columns="4" Margin="0,0,0,10">
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Longest streak" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#F2F2F7" Margin="0,4,0,0">
                                    <Run Text="{Binding LongestStreak, Mode=OneWay}"/><Run Text="d"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Peak hour" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock Text="{Binding PeakHour, Converter={StaticResource PeakHourText}}"
                                           FontSize="22" FontWeight="Bold" Foreground="#F2F2F7"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#2C2C2E" CornerRadius="12" Padding="16,12" Margin="0,0,8,0" Grid.ColumnSpan="2">
                            <StackPanel>
                                <TextBlock Text="Favorite model" FontSize="11" Foreground="#8E8E93"/>
                                <TextBlock Text="{Binding FavoriteModel, FallbackValue=—, TargetNullValue=—}"
                                           FontSize="18" FontWeight="Bold" Foreground="#F2F2F7"
                                           Margin="0,4,0,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Border>
                        <Border Background="Transparent"/>
                    </UniformGrid>

                    <!-- 热力图：12 周 × 7 行的 Day Activity 网格 -->
                    <Border Background="#2C2C2E" CornerRadius="12" Padding="14,12" Margin="0,0,0,10">
                        <ItemsControl ItemsSource="{Binding Heatmap}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="7"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="18" Height="18" Margin="2"
                                            CornerRadius="3"
                                            Background="{Binding Intensity, Converter={StaticResource HeatmapBrush}}"
                                            ToolTip="{Binding Date, StringFormat=yyyy-MM-dd}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- 趣味对照行：tokens 用了多少倍《指环王》—— ComparisonLine 空时整条隐藏 -->
                    <TextBlock Text="{Binding ComparisonLine}"
                               Foreground="#6C6C70" FontSize="11"
                               Margin="2,4,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ============ Models tab ============ -->
            <ScrollViewer Visibility="{Binding IsTabModels, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="24,4,24,16" DataContext="{Binding DashboardStats}">
                    <Border Background="#2C2C2E" CornerRadius="12" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="Token usage by model"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#F2F2F7"
                                       Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Models}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#6FA8E0"
                                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#F2F2F7"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="2" Background="#1F1F21"
                                                    CornerRadius="3" Height="6" Margin="0,0,16,0"
                                                    HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                <Border Background="#6FA8E0" CornerRadius="3"
                                                        HorizontalAlignment="Left"
                                                        Width="{Binding Percentage, StringFormat={}{0}%}"/>
                                            </Border>
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="#8E8E93"
                                                       Margin="0,0,16,0">
                                                <Run Text="{Binding InputTokens, Converter={StaticResource HumanNum}, Mode=OneWay}"/><Run Text=" in · "/><Run Text="{Binding OutputTokens, Converter={StaticResource HumanNum}, Mode=OneWay}"/><Run Text=" out"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="4" Text="{Binding Percentage, StringFormat={}{0:0.#}%}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#F2F2F7"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

<Window x:Class="OpenIsland.App.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenIsland.App"
        Width="320"
        SizeToContent="Height"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:StringToBrushConverter x:Key="StrToBrush"/>

        <!-- 扁平 ScrollBar：去掉箭头按钮 + 滑道，仅保留一根细灰色 thumb。
             默认 WPF ScrollBar 自带 LineUp/LineDown 箭头 + 灰白滑道，跟岛的极简风冲突。 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A"
                                                        CornerRadius="3"
                                                        Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apple 风按钮：白底深字（主，相当于参考图 "Allow"）/ 深底浅字（次，相当于 "Deny"）。
             圆角 9px、左对齐内容（label 长时不截断中线），hover 用 opacity 微调。 -->
        <Style x:Key="AppleButtonPrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AppleButtonSecondary" TargetType="Button" BasedOn="{StaticResource AppleButtonPrimary}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#E5E5EA"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         Notch 模式 = 默认岛"粘到屏顶"换皮：DataTrigger 切外层 Margin 和
         MainBorder 圆角即可，所有内部功能（展开箭头/会话列表/权限拓宽/状态灯）
         保持原样不变。
         ============================================================ -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="10,8,10,12"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                        <Setter Property="Margin" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border x:Name="MainBorder"
                Background="#0D0D0D"
                BorderBrush="#282828"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0,0,18,18"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>

                <!-- ── 折叠头部（始终可见，点击展开/收起） ── -->
                <Grid Height="44" Cursor="Hand"
                      MouseLeftButtonDown="Header_MouseDown"
                      MouseMove="Header_MouseMove"
                      MouseLeftButtonUp="Header_MouseUp"
                      Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：状态灯 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">

                        <!-- 状态灯：蓝=思考中，绿=就绪，红=需关注 -->
                        <Ellipse Width="7" Height="7" Margin="0,0,10,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding StatusDotColor, Converter={StaticResource StrToBrush}}"/>

                        <TextBlock Text="Open Island"
                                   Foreground="#E0E0E0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>

                        <!-- 运行中的会话数量 -->
                        <Border Background="#1E1E1E" CornerRadius="8"
                                Padding="6,1" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAnySessions, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding RunningCount}"
                                       Foreground="#666666"
                                       FontSize="11"/>
                        </Border>
                    </StackPanel>

                    <!-- 右：红色角标 + 展开箭头 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">

                        <Border Background="#C0392B" CornerRadius="9"
                                Padding="7,2" Margin="0,0,9,0"
                                Visibility="{Binding HasAttention, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding AttentionCount}"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock x:Name="Chevron"
                                   Text="›"
                                   Foreground="#444444"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="ChevronRotate" Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── 展开内容 ── -->
                <StackPanel x:Name="ExpandedContent"
                            MaxHeight="0"
                            ClipToBounds="True">

                    <Rectangle Height="1" Fill="#1C1C1C"/>

                    <!-- ======================================================
                         视图切换：权限请求时整岛让位给 1/2/3 三选项专属布局，
                         普通模式下显示运行中会话列表。两个面板互斥可见，岛宽
                         度由 code-behind 根据 IsPermissionMode 动画过渡。
                         ====================================================== -->

                    <!-- 普通模式：会话卡片列表 -->
                    <StackPanel Visibility="{Binding IsPermissionMode, Converter={StaticResource InvBoolToVis}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="350">
                            <ItemsControl ItemsSource="{Binding Sessions}" Margin="8,6,8,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#111111"
                                                CornerRadius="12"
                                                Padding="12,10"
                                                Margin="0,2"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding JumpCommand}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center"
                                                         Margin="3,0,13,0"
                                                         Fill="{Binding StatusColor, Converter={StaticResource StrToBrush}}"/>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#DDDDDD"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="220"/>
                                                    <TextBlock Text="{Binding Elapsed}"
                                                               Foreground="#484848"
                                                               FontSize="11"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- 权限模式：参考 Apple 风 Permission Request 卡片设计 ——
                         上 = 信息区（橙点 + 标题 + 工具 tag + 入参 monospace 块）
                         下 = 选项区（3 键竖排，仅两种配色：白底深字 = 主，深底浅字 = 次）
                         Visibility 必须挂在没有 DataContext 重写的外层 ContentControl 上。 -->
                    <ContentControl Visibility="{Binding IsPermissionMode, Converter={StaticResource BoolToVis}}">
                    <Border DataContext="{Binding PermissionSession}"
                            Background="#1C1C1E"
                            CornerRadius="14"
                            Padding="20,16"
                            Margin="10,8,10,10">
                        <StackPanel>
                            <!-- 信息区头：橙点 + "Permission Request" 标头 + 时间戳 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="9" Height="9"
                                         VerticalAlignment="Center"
                                         Margin="0,0,9,0"
                                         Fill="#FF9F0A"/>
                                <TextBlock Text="Permission Request"
                                           Foreground="#F2F2F7"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#6C6C70"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="280"/>
                                <TextBlock Text="{Binding Elapsed}"
                                           Foreground="#48484A"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Tool tag + headline：⚠ 工具 + 关键参数 -->
                            <TextBlock Text="{Binding PermissionHeadline}"
                                       Foreground="#FFCC8A"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <!-- 入参展开块：monospace + 微深底，像参考图里的 diff/code 预览 -->
                            <Border Background="#0F0F11"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,14">
                                <TextBlock Text="{Binding PermissionFullDetail}"
                                           Foreground="#B5B5BA"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Menlo"
                                           TextWrapping="Wrap"
                                           MaxHeight="160"/>
                            </Border>

                            <!-- 选项区：3 键竖排，仅 2 色配色 -->
                            <Button Content="1. Yes"
                                    Command="{Binding RespondYesCommand}"
                                    Style="{StaticResource AppleButtonPrimary}"
                                    Margin="0,0,0,7"/>
                            <Button Content="{Binding AlwaysButtonLabel}"
                                    Command="{Binding RespondAlwaysCommand}"
                                    Visibility="{Binding ShowAlwaysButton, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource AppleButtonPrimary}"
                                    Margin="0,0,0,7"/>
                            <Button Content="3. No, and tell Claude what to do differently"
                                    Command="{Binding RespondNoCommand}"
                                    Style="{StaticResource AppleButtonSecondary}"/>

                            <TextBlock Text="点击上方任一项，或在 Claude 终端按 1 / 2 / 3"
                                       Foreground="#48484A"
                                       FontSize="10"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    </ContentControl>

                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</Window>

<Window x:Class="OpenIsland.App.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenIsland.App"
        xmlns:views="clr-namespace:OpenIsland.App.Views"
        Width="320"
        SizeToContent="Height"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:StringToBrushConverter x:Key="StrToBrush"/>

        <!-- 扁平 ScrollBar：去掉箭头按钮 + 滑道，仅保留一根细灰色 thumb。
             默认 WPF ScrollBar 自带 LineUp/LineDown 箭头 + 灰白滑道，跟岛的极简风冲突。 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A"
                                                        CornerRadius="3"
                                                        Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apple 风按钮：白底深字（主，相当于参考图 "Allow"）/ 深底浅字（次，相当于 "Deny"）。
             圆角 9px、左对齐内容（label 长时不截断中线），hover 用 opacity 微调。 -->
        <Style x:Key="AppleButtonPrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AppleButtonSecondary" TargetType="Button" BasedOn="{StaticResource AppleButtonPrimary}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#E5E5EA"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         Notch 模式 = 默认岛"粘到屏顶"换皮：DataTrigger 切外层 Margin 和
         MainBorder 圆角即可，所有内部功能（展开箭头/会话列表/权限拓宽/状态灯）
         保持原样不变。
         ============================================================ -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="10,8,10,12"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                        <Setter Property="Margin" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border x:Name="MainBorder"
                Background="#0D0D0D"
                BorderBrush="#282828"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0,0,18,18"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>

                <!-- ── 折叠头部（始终可见，点击展开/收起） ── -->
                <Grid Height="44" Cursor="Hand"
                      MouseLeftButtonDown="Header_MouseDown"
                      MouseMove="Header_MouseMove"
                      MouseLeftButtonUp="Header_MouseUp"
                      Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：状态灯 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">

                        <!-- 像素状态精灵：绑聚合 phase，Running/Attention 动、Idle/Completed 静。
                             32px 原生 ×1 显示（缩小一倍），NearestNeighbor 不糊。 -->
                        <views:PixelStatusSprite Phase="{Binding AggregatePhase}"
                                                 Scale="1"
                                                 Margin="0,0,9,0"
                                                 VerticalAlignment="Center"/>

                        <TextBlock Text="Open Island"
                                   Foreground="#E0E0E0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>

                        <!-- 运行中的会话数量 -->
                        <Border Background="#1E1E1E" CornerRadius="8"
                                Padding="6,1" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAnySessions, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding RunningCount}"
                                       Foreground="#666666"
                                       FontSize="11"/>
                        </Border>
                    </StackPanel>

                    <!-- 右：红色角标 + 展开箭头 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">

                        <Border Background="#C0392B" CornerRadius="9"
                                Padding="7,2" Margin="0,0,9,0"
                                Visibility="{Binding HasAttention, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding AttentionCount}"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock x:Name="Chevron"
                                   Text="›"
                                   Foreground="#444444"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="ChevronRotate" Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- ── 展开内容 ── -->
                <StackPanel x:Name="ExpandedContent"
                            MaxHeight="0"
                            ClipToBounds="True">

                    <Rectangle Height="1" Fill="#1C1C1C"/>

                    <!-- ======================================================
                         视图切换：权限请求时整岛让位给 1/2/3 三选项专属布局，
                         普通模式下显示运行中会话列表。两个面板互斥可见，岛宽
                         度由 code-behind 根据 IsPermissionMode 动画过渡。
                         ====================================================== -->

                    <!-- 普通模式：会话卡片列表 -->
                    <StackPanel Visibility="{Binding IsPermissionMode, Converter={StaticResource InvBoolToVis}}">

                        <!-- ── 系统状态栏：CPU / 内存 / GPU / 网速（夹在头部与会话列表之间） ── -->
                        <Border Background="#111111"
                                CornerRadius="10"
                                Margin="8,6,8,2"
                                Padding="12,8">
                            <Grid>
                                <!-- 四等分固定列（原第 4 列是 Auto，网速文本变宽会把 CPU/RAM/GPU
                                     往左推产生抖动）。改成全部 * 等宽四分之一，CPU/RAM/GPU 位置
                                     固定不再随网速变化；网速列用 CharacterEllipsis 防溢出。
                                     Fixed equal quarters: the old Auto net column resized with the
                                     net text and shifted CPU/RAM/GPU. All * now → fixed positions;
                                     net gets CharacterEllipsis so it can't overflow its quarter.
                                     第 5 列 Auto 给提示音开关按钮（#3）。 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CpuText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding MemText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding GpuText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding NetText}"
                                           Foreground="#7C8A9A"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- 提示音开关（#3）：图标-only 小按钮。绑 SoundEnabled，
                                     DataTrigger 切扬声器/静音字形（Segoe MDL2 Assets，跟媒体栏一致）。
                                     Sound mute toggle: icon-only, MDL2 speaker / muted glyph. -->
                                <Button Grid.Column="4"
                                        Command="{Binding ToggleSoundCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        FocusVisualStyle="{x:Null}"
                                        ToolTip="提示音开 / 关">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SndBd"
                                                    Width="20" Height="20"
                                                    CornerRadius="10"
                                                    Background="Transparent">
                                                <TextBlock x:Name="SndGlyph"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#9AA0A6"
                                                           Text="&#xE767;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- 关闭时换静音字形（喇叭带斜杠 E74F） -->
                                                <DataTrigger Binding="{Binding SoundEnabled}" Value="False">
                                                    <Setter TargetName="SndGlyph" Property="Text" Value="&#xE74F;"/>
                                                    <Setter TargetName="SndGlyph" Property="Foreground" Value="#6A6A6A"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SndBd" Property="Background" Value="#2A2A2A"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="SndBd" Property="Background" Value="#3A3A3A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── 媒体控制栏：上一首 / 播放暂停 / 下一首 / 音量（一行） ── -->
                        <Border Background="#111111"
                                CornerRadius="10"
                                Margin="8,0,8,2"
                                Padding="10,6">
                            <Border.Resources>
                                <!-- 圆形媒体键按钮：透明底，hover 圆形高亮 -->
                                <Style x:Key="MediaBtn" TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Width" Value="26"/>
                                    <Setter Property="Height" Value="26"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Foreground" Value="#C8C8C8"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <!-- 用 Segoe MDL2 Assets 单色图标字形，避免 ⏮⏯⏭ 被
                                         Segoe UI Emoji 渲染成"带圆角方框的 emoji 按钮" -->
                                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                    <!-- 去掉点击后 WPF 默认的焦点虚线框 -->
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="MB"
                                                        Background="Transparent"
                                                        CornerRadius="13">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="MB" Property="Background" Value="#2A2A2A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="MB" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <!-- 极简音量滑块：细灰轨 + 小白点 thumb -->
                                <Style x:Key="VolSlider" TargetType="Slider">
                                    <Setter Property="Minimum" Value="0"/>
                                    <Setter Property="Maximum" Value="100"/>
                                    <Setter Property="IsMoveToPointEnabled" Value="True"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid VerticalAlignment="Center" Height="20">
                                                    <Border Height="4" CornerRadius="2" Background="#333333" VerticalAlignment="Center"/>
                                                    <Track x:Name="PART_Track">
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Width="11" Height="11" Fill="#FFFFFF"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Opacity="0" Command="Slider.IncreaseLarge"/>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Opacity="0" Command="Slider.DecreaseLarge"/>
                                                        </Track.DecreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaPrevCommand}"
                                        Content="&#xE892;" ToolTip="上一首"/>
                                <Button Grid.Column="1" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaPlayPauseCommand}"
                                        Content="&#xE768;" FontSize="15" ToolTip="播放 / 暂停"/>
                                <Button Grid.Column="2" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaNextCommand}"
                                        Content="&#xE893;" ToolTip="下一首"/>

                                <TextBlock Grid.Column="3" Text="&#xE767;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#9AA0A6"
                                           VerticalAlignment="Center"
                                           Margin="8,0,6,0"/>
                                <Slider Grid.Column="4" Style="{StaticResource VolSlider}"
                                        Value="{Binding Volume, Mode=TwoWay}"
                                        Margin="0,0,4,0"
                                        ToolTip="系统音量"/>
                            </Grid>
                        </Border>

                        <!-- ── Plan usage 行：Claude 订阅 5h 滚动窗口用量 ──
                             Plan 模式：Plan + 进度条 + 62% + 重置 2h13m
                             API  模式：API · 1.24M tokens（无进度条/重置）
                             配色/间距对齐上方媒体行（#111111 / CornerRadius 10 / Margin 8,0,8,2）。
                             暂时取消：整行折叠（删掉 Visibility="Collapsed" 即恢复）。 -->
                        <Border Background="#111111"
                                CornerRadius="10"
                                Margin="8,0,8,2"
                                Padding="10,8"
                                Visibility="Collapsed">
                            <Border.Resources>
                                <!-- 扁平进度条：无边框、圆角细条，Foreground 绑 PlanBarColor，
                                     轨道 #26FFFFFF，高度 6。无 code-behind，纯模板实现 -->
                                <Style x:Key="PlanBar" TargetType="ProgressBar">
                                    <Setter Property="Minimum" Value="0"/>
                                    <Setter Property="Maximum" Value="1"/>
                                    <Setter Property="Height" Value="6"/>
                                    <Setter Property="Foreground"
                                            Value="{Binding PlanBarColor, Converter={StaticResource StrToBrush}}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Border CornerRadius="3"
                                                        Background="#26FFFFFF"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Border x:Name="PART_Track"/>
                                                        <Border x:Name="PART_Indicator"
                                                                HorizontalAlignment="Left"
                                                                CornerRadius="3"
                                                                Background="{TemplateBinding Foreground}"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左：Plan / API 标签（灰，跟 CPU/RAM 同字号同色） -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding PlanLabel}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <!-- Plan 模式组：进度条 + 百分比 + 重置 -->
                                <Grid Grid.Column="1"
                                      Visibility="{Binding PlanIsApi, Converter={StaticResource InvBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ProgressBar Grid.Column="0"
                                                 Style="{StaticResource PlanBar}"
                                                 Value="{Binding PlanBarFraction}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlanPercentText}"
                                               Foreground="#E0E0E0"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               FontFamily="Consolas, Cascadia Code, Segoe UI"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlanResetText}"
                                               Foreground="#7C8A9A"
                                               FontSize="10"
                                               FontFamily="Consolas, Cascadia Code, Segoe UI"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>
                                </Grid>

                                <!-- API 模式组：· 1.24M tokens（替代进度条组） -->
                                <TextBlock Grid.Column="1"
                                           Visibility="{Binding PlanIsApi, Converter={StaticResource BoolToVis}}"
                                           Foreground="#E0E0E0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center">
                                    <Run Text="·" Foreground="#7C8A9A"/>
                                    <Run Text="{Binding PlanValueText}"/>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="350">
                            <ItemsControl ItemsSource="{Binding Sessions}" Margin="8,6,8,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#111111"
                                                CornerRadius="12"
                                                Padding="12,10"
                                                Margin="0,2"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding JumpCommand}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0"
                                                         Width="12" Height="12"
                                                         VerticalAlignment="Center"
                                                         Margin="3,0,13,0"
                                                         Fill="{Binding StatusColor, Converter={StaticResource StrToBrush}}"/>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#DDDDDD"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="200"/>
                                                    <TextBlock Text="{Binding Elapsed}"
                                                               Foreground="#484848"
                                                               FontSize="11"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- 卡片右侧操作区：3 个权限模式切换图标按钮 + 原小叉号。
                                                     模式按钮均为 icon-only（无文字标签），hover 提示英文；
                                                     视觉与叉号一致（20x20 / CornerRadius 10 / hover #2A2A2A）。
                                                     全是 Button —— 跟叉号一样自己吃掉点击，不触发卡片 JumpCommand。
                                                     注意：Claude Code 切权限模式靠终端 Shift+Tab 轮询，没有
                                                     幂等的"设为模式 X"按键，所以这三个按钮是尽力而为
                                                     (best-effort)：每次点发一次 Shift+Tab 循环一格，不保证
                                                     精确落到目标模式（详见 SessionManager.SendModeSwitchAsync）。
                                                     Row of 3 permission-mode toggles + the original ✕. Mode
                                                     buttons are icon-only; English tooltip on hover. Delivery is
                                                     best-effort (Claude Code cycles modes via Shift+Tab; no
                                                     idempotent set-mode key) — see SendModeSwitchAsync. -->
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <StackPanel.Resources>
                                                        <!-- 共用：20x20 圆角图标按钮模板（叉号同款 hover） -->
                                                        <Style x:Key="CardIconBtn" TargetType="Button">
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Margin" Value="2,0,0,0"/>
                                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="IBd"
                                                                                Width="20" Height="20"
                                                                                CornerRadius="10"
                                                                                Background="Transparent">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="IBd" Property="Background" Value="#2A2A2A"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="IBd" Property="Background" Value="#3A3A3A"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </StackPanel.Resources>

                                                    <!-- accept edits（接受编辑模式）E73E = 勾选框字形 -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding AcceptEditsCommand}"
                                                            ToolTip="accept edits">
                                                        <TextBlock Text="&#xE73E;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="#5A5A5A"/>
                                                    </Button>
                                                    <!-- auto mode（自动模式）E945 = 闪电字形 -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding AutoModeCommand}"
                                                            ToolTip="auto mode">
                                                        <TextBlock Text="&#xE945;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="#5A5A5A"/>
                                                    </Button>
                                                    <!-- plan mode（计划模式）E70F = 编辑/铅笔字形 -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding PlanModeCommand}"
                                                            ToolTip="plan mode">
                                                        <TextBlock Text="&#xE70F;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="#5A5A5A"/>
                                                    </Button>

                                                    <!-- 快捷回复：点开/收起输入框（E8BD = 评论字形） -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding ToggleQuickReplyCommand}"
                                                            ToolTip="快捷回复（敲字回车发送）">
                                                        <TextBlock Text="&#xE8BD;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="#5A5A5A"/>
                                                    </Button>

                                                    <!-- 小叉号：临时把这条 session 从灵动岛收起，
                                                         再次活动时自动放回。Button 自己吃掉点击，
                                                         不会触发卡片的 JumpCommand。（保持原样，放最后） -->
                                                    <Button Command="{Binding DismissCommand}"
                                                            VerticalAlignment="Center"
                                                            Margin="6,0,0,0"
                                                            Cursor="Hand"
                                                            ToolTip="暂时收起（再次活动时自动出现）">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="XBd"
                                                                        Width="20" Height="20"
                                                                        CornerRadius="10"
                                                                        Background="Transparent">
                                                                    <TextBlock Text="✕"
                                                                               FontSize="11"
                                                                               Foreground="#5A5A5A"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="XBd" Property="Background" Value="#2A2A2A"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="XBd" Property="Background" Value="#3A3A3A"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>

                                                <!-- 快捷回复输入行（F1）：点回复图标展开；敲字回车发送（发送前校验目标终端在前台，否则中止） -->
                                                <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0"
                                                        Visibility="{Binding ShowQuickReply, Converter={StaticResource BoolToVis}}">
                                                    <StackPanel>
                                                        <!-- 模型切换（F2）：选中即切换；Claude 档实时，第三方写 env 重开终端生效 -->
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="模型" Foreground="#777777" FontSize="11"
                                                                       VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                            <ComboBox Grid.Column="1"
                                                                      ItemsSource="{Binding SelectableModels}"
                                                                      SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                                                                      DisplayMemberPath="Name"
                                                                      Background="#1C1C1E" Foreground="#DDDDDD"
                                                                      FontSize="11" Height="24"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding ModelStatus}" Foreground="#777777" FontSize="10" Margin="2,0,0,6">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ModelStatus}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ModelStatus}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0">
                                                                <TextBox Text="{Binding QuickReplyInput, UpdateSourceTrigger=PropertyChanged}"
                                                                         Background="#0D0D0D" Foreground="#DDDDDD"
                                                                         BorderBrush="#2A2A2A" BorderThickness="1"
                                                                         CaretBrush="#DDDDDD" FontSize="11"
                                                                         Padding="6,3" VerticalContentAlignment="Center"
                                                                         MaxLines="3" TextWrapping="Wrap" AcceptsReturn="False">
                                                                    <TextBox.InputBindings>
                                                                        <KeyBinding Key="Enter" Command="{Binding SendQuickReplyCommand}"/>
                                                                    </TextBox.InputBindings>
                                                                </TextBox>
                                                                <TextBlock Text="回复… 回车发送" Foreground="#555555" FontSize="11"
                                                                           Margin="8,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding QuickReplyInput}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Button Grid.Column="1" Command="{Binding SendQuickReplyCommand}"
                                                                    Margin="6,0,0,0" Cursor="Hand" ToolTip="发送（回车）"
                                                                    FocusVisualStyle="{x:Null}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="SBd" Width="26" Height="24" CornerRadius="6"
                                                                                Background="Transparent">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="SBd" Property="Background" Value="#2A2A2A"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="SBd" Property="Background" Value="#3A3A3A"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="12" Foreground="#0A84FF"/>
                                                            </Button>
                                                        </Grid>
                                                        <TextBlock Text="{Binding QuickReplyStatus}" Foreground="#777777" FontSize="10" Margin="2,3,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding QuickReplyStatus}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding QuickReplyStatus}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- 权限模式：参考 Apple 风 Permission Request 卡片设计 ——
                         上 = 信息区（橙点 + 标题 + 工具 tag + 入参 monospace 块）
                         下 = 选项区（3 键竖排，仅两种配色：白底深字 = 主，深底浅字 = 次）
                         Visibility 必须挂在没有 DataContext 重写的外层 ContentControl 上。 -->
                    <ContentControl Visibility="{Binding IsPermissionMode, Converter={StaticResource BoolToVis}}">
                    <Border DataContext="{Binding PermissionSession}"
                            Background="#1C1C1E"
                            CornerRadius="14"
                            Padding="20,16"
                            Margin="10,8,10,10">
                        <StackPanel>
                            <!-- 信息区头：橙点 + "Permission Request" 标头 + 时间戳 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="9" Height="9"
                                         VerticalAlignment="Center"
                                         Margin="0,0,9,0"
                                         Fill="#FF9F0A"/>
                                <TextBlock Text="Permission Request"
                                           Foreground="#F2F2F7"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#6C6C70"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="280"/>
                                <TextBlock Text="{Binding Elapsed}"
                                           Foreground="#48484A"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Tool tag + headline：⚠ 工具 + 关键参数 -->
                            <TextBlock Text="{Binding PermissionHeadline}"
                                       Foreground="#FFCC8A"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <!-- 入参展开块：monospace + 微深底，像参考图里的 diff/code 预览 -->
                            <Border Background="#0F0F11"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,14">
                                <TextBlock Text="{Binding PermissionFullDetail}"
                                           Foreground="#B5B5BA"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Menlo"
                                           TextWrapping="Wrap"
                                           MaxHeight="160"/>
                            </Border>

                            <!-- ===========================================================
                                 选项区两套互斥（IsQuestion 切换，绑在 PermissionSession
                                 这个 DataContext 上 —— 与 YesButtonLabel 等同级，可达）：
                                  · IsQuestion=false → 普通工具权限：Allow once / (Always) /
                                    Deny，文案按 entrypoint 走（行为 100% 不变）。
                                  · IsQuestion=true  → AskUserQuestion：每个候选答案一个
                                    按钮（"{Number}. {Label}"，description 作副文案 + ToolTip），
                                    竖排可滚，末尾一个 Skip。点击 → AnswerQuestionCommand
                                    (CommandParameter=Number) / SkipQuestionCommand。
                                 =========================================================== -->

                            <!-- 普通权限按钮组（IsQuestion=false 时显示） -->
                            <StackPanel Visibility="{Binding IsQuestion, Converter={StaticResource InvBoolToVis}}">
                                <Button Content="{Binding YesButtonLabel}"
                                        Command="{Binding RespondYesCommand}"
                                        Style="{StaticResource AppleButtonPrimary}"
                                        Margin="0,0,0,7"/>
                                <Button Content="{Binding AlwaysButtonLabel}"
                                        Command="{Binding RespondAlwaysCommand}"
                                        Visibility="{Binding ShowAlwaysButton, Converter={StaticResource BoolToVis}}"
                                        Style="{StaticResource AppleButtonPrimary}"
                                        Margin="0,0,0,7"/>
                                <Button Content="{Binding NoButtonLabel}"
                                        Command="{Binding RespondNoCommand}"
                                        Style="{StaticResource AppleButtonSecondary}"/>
                            </StackPanel>

                            <!-- AskUserQuestion 选项按钮组（IsQuestion=true 时显示） -->
                            <StackPanel Visibility="{Binding IsQuestion, Converter={StaticResource BoolToVis}}">
                                <!-- 选项可能较多 —— 限高滚动（复用全局扁平 ScrollBar 样式） -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              MaxHeight="260">
                                    <ItemsControl ItemsSource="{Binding QuestionOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 整行一个按钮：主行 "{Number}. {Label}" +
                                                     description 小字副行；description 同时挂
                                                     ToolTip（长描述行内省略后仍可悬停看全文）。
                                                     复用 Apple 主按钮观感（白底深字 + 圆角 9）。 -->
                                                <Button Command="{Binding DataContext.AnswerQuestionCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Number}"
                                                        Style="{StaticResource AppleButtonPrimary}"
                                                        HorizontalContentAlignment="Left"
                                                        Margin="0,0,0,7"
                                                        ToolTip="{Binding Description}">
                                                    <StackPanel>
                                                        <TextBlock FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#1C1C1E"
                                                                   TextWrapping="Wrap">
                                                            <Run Text="{Binding Number, Mode=OneWay}"/><Run Text=". "/><Run Text="{Binding Label, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Description}"
                                                                   FontSize="11"
                                                                   Foreground="#6C6C70"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,3,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <!-- 没 description 就整行折叠，不留空白 -->
                                                                        <DataTrigger Binding="{Binding Description}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- Skip：跳过该问题（深底浅字次按钮，与 Deny 同观感） -->
                                <Button Content="Skip"
                                        Command="{Binding SkipQuestionCommand}"
                                        Style="{StaticResource AppleButtonSecondary}"
                                        Margin="0,3,0,0"/>
                            </StackPanel>

                            <TextBlock Text="{Binding PermissionHintText}"
                                       Foreground="#48484A"
                                       FontSize="10"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    </ContentControl>

                </StackPanel>

            </StackPanel>
        </Border>
    </Border>
</Window>

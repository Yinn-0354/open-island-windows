<Window x:Class="OpenIsland.App.Views.DynamicIslandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenIsland.App"
        xmlns:views="clr-namespace:OpenIsland.App.Views"
        xmlns:svc="clr-namespace:OpenIsland.App.Services"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        xmlns:ae="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        Width="384"
        SizeToContent="Height"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:StringToBrushConverter x:Key="StrToBrush"/>
        <!-- 胶囊背景：液态玻璃帧 or 纯黑兜底（见 GlassBackgroundConverter） -->
        <local:GlassBackgroundConverter x:Key="GlassBg"/>
        <!-- 展开后内部面板/卡片填充：玻璃开 → 半透明（透出毛玻璃），关 → 原黑色。
             用 DynamicResource 引用，代码后端 ApplyGlassResources 一处切换全部生效（含 DataTemplate 内的卡片）。 -->
        <SolidColorBrush x:Key="CardFill" Color="#111111"/>
        <SolidColorBrush x:Key="PanelFill" Color="#1C1C1E"/>
        <SolidColorBrush x:Key="CodeFill" Color="#0F0F11"/>
        <!-- 模型切换栏里那排按钮 chip：玻璃开 → 半透明毛玻璃，关 → 原暖深色。 -->
        <SolidColorBrush x:Key="ChipFill" Color="#252320"/>
        <SolidColorBrush x:Key="ChipHover" Color="#2F2C28"/>
        <!-- 圆形 chip 的方向性高光环（仿 liquid-glass-react：135° 对角线，中下最亮） -->
        <LinearGradientBrush x:Key="ChipRim" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#00FFFFFF" Offset="0"/>
            <GradientStop Color="#26FFFFFF" Offset="0.32"/>
            <GradientStop Color="#88FFFFFF" Offset="0.60"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <!-- ══════════════════════════════════════════════════════════════════
             ExitPlanMode 计划审阅：MdXaml MarkdownScrollViewer 深色主题适配。
             MdXaml 自带的 "Standard" 文档样式是给白纸设计的（标题/代码块背景都刺眼的白/
             接近纯黑文字），直接糊在岛的黑色胶囊卡片上会变成一坨刺眼白块或黑字糊黑底。
             这里用两层手段：
               1) PlanMdDocumentStyle：BasedOn 官方 Standard（保留其 FontFamily/对齐/
                  页边距），只覆盖 Foreground 为浅色 —— 正文/列表/引用块都靠 FlowDocument
                  的属性继承拿到这个浅色，不用逐个元素单独处理。
               2) PlanMdH1..H6Style：MdXaml 标题另有一套内置的 Trigger（按 Paragraph.Tag
                  =="Heading1".."Heading6" 触发），会把标题 Foreground 硬编码成黑色/半透明
                  黑 —— Trigger 设的值优先级比继承高，光靠 (1) 盖不掉标题。所以显式提供
                  Heading1Style..Heading6Style（挂在 MarkdownScrollViewer.Engine 那个
                  Markdown 引擎对象上，见下方 XAML），整体替换掉那套内置 Trigger。
             代码块（```lang```）由 MdXaml 转成内嵌的 AvalonEdit TextEditor 控件渲染，
             它默认白底黑字 —— 这个反而不能单靠 XAML 资源覆盖：TextEditor 是运行时动态
             创建、挂在 FlowDocument 的 BlockUIContainer 里，WPF 的隐式样式自动解析
             （AncestorChanged 触发链）在这种宿主场景下不可靠地生效（实测：Window.Resources /
             MarkdownScrollViewer.Resources 里声明的隐式 Style 均不会被拿去用，哪怕
             TryFindResource 手动查证明资源链本身是通的）。因此代码块改由
             DynamicIslandWindow.xaml.cs 里的 FixPlanCodeBlockColors 在每次 Document
             变化时，直接对内嵌的 TextEditor 设本地属性值（本地值优先级最高，稳赢
             AvalonEdit 自带主题样式）。
             ══════════════════════════════════════════════════════════════════ -->
        <Style x:Key="PlanMdDocumentStyle" TargetType="{x:Type FlowDocument}"
               BasedOn="{x:Static mdxaml:MarkdownStyle.Standard}">
            <Setter Property="Foreground" Value="#E5E5EA"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>
        <Style x:Key="PlanMdH1Style" TargetType="{x:Type Paragraph}">
            <Setter Property="Foreground" Value="#F2F2F7"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style x:Key="PlanMdH2Style" TargetType="{x:Type Paragraph}" BasedOn="{StaticResource PlanMdH1Style}">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style x:Key="PlanMdH3Style" TargetType="{x:Type Paragraph}" BasedOn="{StaticResource PlanMdH1Style}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#E5E5EA"/>
        </Style>
        <Style x:Key="PlanMdH4Style" TargetType="{x:Type Paragraph}" BasedOn="{StaticResource PlanMdH3Style}">
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="PlanMdH5Style" TargetType="{x:Type Paragraph}" BasedOn="{StaticResource PlanMdH4Style}"/>
        <Style x:Key="PlanMdH6Style" TargetType="{x:Type Paragraph}" BasedOn="{StaticResource PlanMdH4Style}"/>

        <!-- 扁平 ScrollBar：去掉箭头按钮 + 滑道，仅保留一根细灰色 thumb。
             默认 WPF ScrollBar 自带 LineUp/LineDown 箭头 + 灰白滑道，跟岛的极简风冲突。 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A3A3A"
                                                        CornerRadius="3"
                                                        Margin="1,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apple 风按钮：白底深字（主，相当于参考图 "Allow"）/ 深底浅字（次，相当于 "Deny"）。
             圆角 9px、左对齐内容（label 长时不截断中线），hover 用 opacity 微调。 -->
        <Style x:Key="AppleButtonPrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AppleButtonSecondary" TargetType="Button" BasedOn="{StaticResource AppleButtonPrimary}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#E5E5EA"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#48484A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- ============================================================
         Notch 模式 = 默认岛"粘到屏顶"换皮：DataTrigger 切外层 Margin 和
         MainBorder 圆角即可，所有内部功能（展开箭头/会话列表/权限拓宽/状态灯）
         保持原样不变。
         ============================================================ -->
    <Border>
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Margin" Value="10,8,10,12"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                        <Setter Property="Margin" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border x:Name="MainBorder"
                BorderBrush="#282828"
                BorderThickness="1">
            <!-- 背景：液态玻璃开 ⇒ 离屏渲染的玻璃帧；否则纯黑 #0D0D0D。Border 自动按 CornerRadius 裁圆角。 -->
            <Border.Background>
                <MultiBinding Converter="{StaticResource GlassBg}">
                    <Binding Path="LiquidGlassEnabled"/>
                    <Binding Path="GlassFrame"/>
                </MultiBinding>
            </Border.Background>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="20"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsNotchMode}" Value="True">
                            <Setter Property="CornerRadius" Value="0,0,18,18"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <!-- 正在播放·波浪律动：叠加在 MainBorder 背景之上、其余内容之下的一层装饰层
                     （不改 MainBorder.Background 本身的黑色/玻璃切换逻辑，两者共存）。
                     OpacityMask 用 VisualBrush 绑 MainBorder 的实时尺寸 + CornerRadius 做圆角裁剪——
                     CornerRadius 在 Notch 模式下是非对称的(0,0,18,18)，Border 自身渲染背景能正确处理
                     这种混合圆角，借它的内部 chrome 当遮罩比自建 RectangleGeometry（只能统一圆角）更准确，
                     且随 MainBorder 尺寸/圆角变化自动联动，不用另写代码同步。 -->
                <views:WaveVisual x:Name="NowPlayingWave"
                                  IsHitTestVisible="False"
                                  Color1="{Binding WaveColor1}"
                                  Color2="{Binding WaveColor2}"
                                  Color3="{Binding WaveColor3}"
                                  Amplitude="{Binding WaveAmplitude}"
                                  Visibility="{Binding ShowNowPlayingWave, Converter={StaticResource BoolToVis}}">
                    <views:WaveVisual.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Border Width="{Binding ActualWidth, ElementName=MainBorder}"
                                        Height="{Binding ActualHeight, ElementName=MainBorder}"
                                        CornerRadius="{Binding CornerRadius, ElementName=MainBorder}"
                                        Background="White"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </views:WaveVisual.OpacityMask>
                </views:WaveVisual>

            <StackPanel>

                <!-- ── 折叠头部（始终可见，点击展开/收起） ── -->
                <Grid Height="44" Cursor="Hand"
                      MouseLeftButtonDown="Header_MouseDown"
                      MouseMove="Header_MouseMove"
                      MouseLeftButtonUp="Header_MouseUp"
                      Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：状态灯 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">

                        <!-- 像素状态精灵：绑聚合 phase，Running/Attention 动、Idle/Completed 静。
                             32px 原生 ×1 布局占位 + Zoom 1.3 视觉放大（44px 行高里 Scale=2
                             的 64px 放不下）；左右边距给放大溢出留位，文字相应右移。 -->
                        <views:PixelStatusSprite x:Name="StatusSprite"
                                                 Phase="{Binding AggregatePhase}"
                                                 MultiAgent="{Binding HasMultipleAgents}"
                                                 Scale="1"
                                                 Zoom="1.3"
                                                 Margin="6,0,17,0"
                                                 VerticalAlignment="Center"
                                                 Cursor="Hand"
                                                 ToolTip="点我一下试试 / Click me"/>

                        <!-- 头部标题：默认 "Open Island"；正在播放时切成曲名。曲名可能比容器宽，
                             用定宽 + ClipToBounds 容器 + TranslateTransform 做跑马灯（DynamicIslandWindow.xaml.cs
                             的 UpdateTitleMarquee 按文字实际宽度决定要不要起循环动画）。 -->
                        <Border x:Name="TitleClip" Width="140" ClipToBounds="True" VerticalAlignment="Center">
                            <TextBlock x:Name="TitleText"
                                       Text="{Binding HeaderTitleText}"
                                       Foreground="#E0E0E0"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       VerticalAlignment="Center"
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform x:Name="TitleTranslate" X="0"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>

                        <!-- 运行中的会话数量：Background 跟 ChipFill 走，液态玻璃开启时随之磨砂化 -->
                        <Border Background="{DynamicResource ChipFill}" CornerRadius="8"
                                Padding="6,1" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAnySessions, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding RunningCount}"
                                       Foreground="#666666"
                                       FontSize="11"/>
                        </Border>
                    </StackPanel>

                    <!-- 右：红色角标 + 展开箭头 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,14,0">

                        <Border Background="#C0392B" CornerRadius="9"
                                Padding="7,2" Margin="0,0,9,0"
                                Visibility="{Binding HasAttention, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding AttentionCount}"
                                       Foreground="White" FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>

                        <TextBlock x:Name="Chevron"
                                   Text="›"
                                   Foreground="#444444"
                                   FontSize="18"
                                   VerticalAlignment="Center"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform x:Name="ChevronRotate" Angle="90"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <!-- 网页同步按钮：MDL2 地球图标。点击开/关内置迷你 HTTP 服务（端口 18686），
                             手机/平板在同一局域网打开链接（开启时已自动复制）即可实时查看会话。
                             开 = 图标变绿 + 暗绿底；ToolTip 动态显示说明或访问地址。 -->
                        <Button x:Name="WebSyncBtn" Command="{Binding ToggleWebSyncCommand}"
                                ToolTip="{Binding WebSyncTip}" Cursor="Hand"
                                Margin="10,0,0,0" VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}" local:Anim.PressScale="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Wc" Width="18" Height="18" CornerRadius="9"
                                            Background="{DynamicResource ChipFill}">
                                        <TextBlock x:Name="WebGlyph" Text="&#xE774;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="10" Foreground="#9AA0A6"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Wc" Property="Background" Value="{DynamicResource ChipHover}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding WebSyncOn}" Value="True">
                                            <Setter TargetName="WebGlyph" Property="Foreground" Value="#4CAF50"/>
                                            <Setter TargetName="Wc" Property="Background" Value="#1E3A26"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 圆形关闭按钮：点击 → 小人挥手拜拜 → 隐藏灵动岛（托盘可再显示）。
                             图标为「关机键」电源符号(圆环留顶部缺口 + 竖线)，矢量 Path 绘制不依赖字体。
                             风格与现有 UI 一致：暗底圆形，hover 变红(#C0392B，同需关注角标色)，图标转白。 -->
                        <Button x:Name="CloseBtn" Click="CloseIsland_Click" Cursor="Hand"
                                Margin="10,0,0,0" VerticalAlignment="Center"
                                FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                ToolTip="关闭灵动岛 / Close">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Cc" Width="18" Height="18" CornerRadius="9"
                                            Background="{DynamicResource ChipFill}">
                                        <!-- 用 Canvas 绝对坐标在 18x18 空间里画电源符号：环心精确落在圆心 (9,9)，
                                             竖线从顶部缺口穿入。避免 Path bbox 对齐导致的偏下偏移。 -->
                                        <Canvas Width="18" Height="18">
                                            <Path x:Name="PwrIcon" Stroke="#9AA0A6" StrokeThickness="1.4"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Data="M 11.22,5.44 A 4.2,4.2 0 1 1 6.78,5.44 M 9,3.2 L 9,8.6"/>
                                        </Canvas>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Cc" Property="Background" Value="#C0392B"/>
                                            <Setter TargetName="PwrIcon" Property="Stroke" Value="#FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- ── 展开内容 ── -->
                <StackPanel x:Name="ExpandedContent"
                            MaxHeight="0"
                            ClipToBounds="True">

                    <Rectangle Height="1" Fill="#1C1C1C"/>

                    <!-- ======================================================
                         视图切换：权限请求时整岛让位给 1/2/3 三选项专属布局，
                         普通模式下显示运行中会话列表。两个面板互斥可见，岛宽
                         度由 code-behind 根据 IsPermissionMode 动画过渡。
                         ====================================================== -->

                    <!-- 普通模式：会话卡片列表 -->
                    <StackPanel Visibility="{Binding IsPermissionMode, Converter={StaticResource InvBoolToVis}}">

                        <!-- ── 系统状态栏：CPU / 内存 / GPU / 网速（夹在头部与会话列表之间） ── -->
                        <Border Background="{DynamicResource CardFill}"
                                CornerRadius="10"
                                Margin="8,6,8,2"
                                Padding="12,8">
                            <Grid>
                                <!-- 四等分固定列（原第 4 列是 Auto，网速文本变宽会把 CPU/RAM/GPU
                                     往左推产生抖动）。改成全部 * 等宽四分之一，CPU/RAM/GPU 位置
                                     固定不再随网速变化；网速列用 CharacterEllipsis 防溢出。
                                     Fixed equal quarters: the old Auto net column resized with the
                                     net text and shifted CPU/RAM/GPU. All * now → fixed positions;
                                     net gets CharacterEllipsis so it can't overflow its quarter.
                                     第 5 列 Auto 给提示音开关按钮（#3）。 -->
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- CPU / RAM 文本：点击释放内存（清理各进程工作集，RAM% 随后下降） -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding CpuText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           ToolTip="{Binding [Mem_Release_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding ReleaseMemoryCommand}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding MemText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           Cursor="Hand"
                                           ToolTip="{Binding [Mem_Release_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <TextBlock.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding ReleaseMemoryCommand}"/>
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding GpuText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding NetText}"
                                           Foreground="#7C8A9A"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- 提示音开关（#3）：图标-only 小按钮。绑 SoundEnabled，
                                     DataTrigger 切扬声器/静音字形（Segoe MDL2 Assets，跟媒体栏一致）。
                                     Sound mute toggle: icon-only, MDL2 speaker / muted glyph. -->
                                <Button Grid.Column="4"
                                        Command="{Binding ToggleSoundCommand}"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        FocusVisualStyle="{x:Null}"
                                        ToolTip="{Binding [Island_Sound_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="SndBd"
                                                    Width="20" Height="20"
                                                    CornerRadius="10"
                                                    Background="Transparent">
                                                <TextBlock x:Name="SndGlyph"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="12"
                                                           Foreground="#9AA0A6"
                                                           Text="&#xE767;"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- 关闭时换静音字形（喇叭带斜杠 E74F） -->
                                                <DataTrigger Binding="{Binding SoundEnabled}" Value="False">
                                                    <Setter TargetName="SndGlyph" Property="Text" Value="&#xE74F;"/>
                                                    <Setter TargetName="SndGlyph" Property="Foreground" Value="#6A6A6A"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SndBd" Property="Background" Value="#2A2A2A"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="SndBd" Property="Background" Value="#3A3A3A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- ── 媒体控制栏：上一首 / 播放暂停 / 下一首 / 音量（一行） ── -->
                        <Border Background="{DynamicResource CardFill}"
                                CornerRadius="10"
                                Margin="8,0,8,2"
                                Padding="10,6">
                            <Border.Resources>
                                <!-- 圆形媒体键按钮：透明底，hover 圆形高亮 -->
                                <Style x:Key="MediaBtn" TargetType="Button">
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="local:Anim.PressScale" Value="True"/>
                                    <Setter Property="Width" Value="26"/>
                                    <Setter Property="Height" Value="26"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Foreground" Value="#C8C8C8"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <!-- 用 Segoe MDL2 Assets 单色图标字形，避免 ⏮⏯⏭ 被
                                         Segoe UI Emoji 渲染成"带圆角方框的 emoji 按钮" -->
                                    <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
                                    <!-- 去掉点击后 WPF 默认的焦点虚线框 -->
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="MB"
                                                        Background="Transparent"
                                                        CornerRadius="13">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="MB" Property="Background" Value="#2A2A2A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="MB" Property="Background" Value="#3A3A3A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <!-- 极简音量滑块：细灰轨 + 小白点 thumb -->
                                <Style x:Key="VolSlider" TargetType="Slider">
                                    <Setter Property="Minimum" Value="0"/>
                                    <Setter Property="Maximum" Value="100"/>
                                    <Setter Property="IsMoveToPointEnabled" Value="True"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Slider">
                                                <Grid VerticalAlignment="Center" Height="20">
                                                    <Border Height="4" CornerRadius="2" Background="#333333" VerticalAlignment="Center"/>
                                                    <Track x:Name="PART_Track">
                                                        <Track.Thumb>
                                                            <Thumb>
                                                                <Thumb.Template>
                                                                    <ControlTemplate TargetType="Thumb">
                                                                        <Ellipse Width="11" Height="11" Fill="#FFFFFF"/>
                                                                    </ControlTemplate>
                                                                </Thumb.Template>
                                                            </Thumb>
                                                        </Track.Thumb>
                                                        <Track.IncreaseRepeatButton>
                                                            <RepeatButton Opacity="0" Command="Slider.IncreaseLarge"/>
                                                        </Track.IncreaseRepeatButton>
                                                        <Track.DecreaseRepeatButton>
                                                            <RepeatButton Opacity="0" Command="Slider.DecreaseLarge"/>
                                                        </Track.DecreaseRepeatButton>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaPrevCommand}"
                                        Content="&#xE892;" ToolTip="{Binding [Island_Prev], Source={x:Static svc:Loc.Instance}}"/>
                                <Button Grid.Column="1" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaPlayPauseCommand}"
                                        Content="{Binding PlayPauseGlyph}" FontSize="15" ToolTip="{Binding [Island_PlayPause], Source={x:Static svc:Loc.Instance}}"/>
                                <Button Grid.Column="2" Style="{StaticResource MediaBtn}"
                                        Command="{Binding MediaNextCommand}"
                                        Content="&#xE893;" ToolTip="{Binding [Island_Next], Source={x:Static svc:Loc.Instance}}"/>

                                <TextBlock Grid.Column="3" Text="&#xE767;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#9AA0A6"
                                           VerticalAlignment="Center"
                                           Margin="8,0,6,0"/>
                                <Slider Grid.Column="4" Style="{StaticResource VolSlider}"
                                        Value="{Binding Volume, Mode=TwoWay}"
                                        Margin="0,0,4,0"
                                        ToolTip="{Binding [Island_Volume], Source={x:Static svc:Loc.Instance}}"/>
                            </Grid>
                        </Border>

                        <!-- ── 模型切换栏：一个按钮，点开弹出模型列表即切换（不显示当前模型）；最右 * 留空 ── -->
                        <Border Background="{DynamicResource CardFill}" CornerRadius="10" Margin="8,0,8,2" Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 切换模型：图标-only（芯片字形 + 小箭头），悬停出提示 —— 本行按钮统一只用
                                     图标，文字全部放 ToolTip（320 宽岛体放不下四个带字按钮）。 -->
                                <ToggleButton x:Name="ModelMenuToggle" Grid.Column="0" Cursor="Hand"
                                              FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                              IsChecked="{Binding ModelMenuOpen, Mode=TwoWay}"
                                              ToolTip="{Binding [Island_SwitchModel], Source={x:Static svc:Loc.Instance}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd" Width="30" Height="30" Background="{DynamicResource ChipFill}"
                                                    BorderBrush="{StaticResource ChipRim}" BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <Popup PlacementTarget="{Binding ElementName=ModelMenuToggle}" Placement="Bottom"
                                       VerticalOffset="4" IsOpen="{Binding ModelMenuOpen, Mode=TwoWay}"
                                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#252320" BorderBrush="#3A3631" BorderThickness="1"
                                            CornerRadius="8" Padding="4" MinWidth="170">
                                        <ItemsControl ItemsSource="{Binding ModelChoices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Cursor="Hand" FocusVisualStyle="{x:Null}"
                                                            Command="{Binding DataContext.SwitchToModelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="IBd" Background="Transparent" CornerRadius="6" Padding="10,6" Margin="1">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="IBd" Property="Background" Value="#2F2C28"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <TextBlock Text="{Binding Name}" Foreground="#FAF9F5" FontSize="12"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </Popup>

                                <!-- 截图按钮 + 清理任务：放在同一横排（Grid 第 1 列）。 -->
                                <StackPanel Grid.Column="1" Orientation="Horizontal">

                                <!-- 背景样式：液态玻璃 ⇄ 纯黑。圆形玻璃 chip（与本行其它按钮同款）；
                                     开启时 chip 底色变亮(ChipHover)作激活指示。点击切换，关闭/渲染失败回退纯黑。 -->
                                <Button x:Name="GlassChip" Cursor="Hand" Margin="6,0,0,0"
                                        FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                        Command="{Binding ToggleLiquidGlassCommand}"
                                        ToolTip="背景样式：液态玻璃 / 纯黑">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Glb" Width="30" Height="30" Background="{DynamicResource ChipFill}"
                                                    BorderBrush="{StaticResource ChipRim}" BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock Text="&#xE771;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Glb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                <DataTrigger Binding="{Binding LiquidGlassEnabled}" Value="True">
                                                    <Setter TargetName="Glb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 正在播放·波浪律动：开 ⇄ 关。开启时读 SMTC 曲名 + 系统混音响度，
                                     胶囊内叠加音浪、头部标题跑马灯显示曲名；关闭时两个后台服务都停掉省资源。
                                     不靠变色区分开关——关闭时图标上叠一道斜杠（跟提示音静音同款语义）。 -->
                                <Button x:Name="WaveChip" Cursor="Hand" Margin="6,0,0,0"
                                        FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                        Command="{Binding ToggleNowPlayingWaveCommand}"
                                        ToolTip="正在播放·波浪律动：开 / 关">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Wvb" Width="30" Height="30" Background="{DynamicResource ChipFill}"
                                                    BorderBrush="{StaticResource ChipRim}" BorderThickness="1.3" CornerRadius="15">
                                                <Grid Width="30" Height="30">
                                                    <TextBlock Text="&#xEC4F;" FontFamily="Segoe MDL2 Assets"
                                                               Foreground="#FFFFFF" FontSize="12"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <!-- 关闭时才显示这道斜杠；开启时收起（InvBoolToVis 反转） -->
                                                    <Line X1="8" Y1="21" X2="21" Y2="8"
                                                          Stroke="#FFFFFF" StrokeThickness="1.6"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Visibility="{Binding NowPlayingWaveEnabled, Converter={StaticResource InvBoolToVis}}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Wvb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 区域截图：微信式拖拽框选 → 复制到剪贴板。快捷键默认 Ctrl+Q（设置中心可改）。
                     注意：本行四个按钮（切换模型/截图/清理任务/安装Skill）合计宽度贴近 320 宽
                     岛体的可用空间，间距/内边距都压过 —— 再加按钮前先量宽度。 -->
                                <Button x:Name="ScreenshotBtn" Cursor="Hand" Margin="6,0,0,0"
                                        FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                        Command="{Binding ScreenshotCommand}" ToolTip="{Binding [Island_Screenshot_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Sb" Width="30" Height="30" Background="{DynamicResource ChipFill}" BorderBrush="{StaticResource ChipRim}"
                                                    BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock Text="&#xE924;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Sb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Sb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 清理任务：显式清空已结束/空闲的任务卡片（保留正在跑的）；与切换模型同款暖深色风格 -->
                                <Button x:Name="ClearTasksBtn" Cursor="Hand" Margin="6,0,0,0"
                                        FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                        Command="{Binding ClearTasksCommand}" ToolTip="{Binding [Island_ClearTasks_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Cb" Width="30" Height="30" Background="{DynamicResource ChipFill}" BorderBrush="{StaticResource ChipRim}"
                                                    BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Cb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Cb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 安装 Skill：点开小面板，粘贴 claude plugin 命令 / owner/repo → 后台 PowerShell 静默安装 -->
                                <ToggleButton x:Name="SkillBtn" Cursor="Hand" Margin="6,0,0,0"
                                              FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                              IsChecked="{Binding SkillMenuOpen, Mode=TwoWay}"
                                              ToolTip="{Binding [Island_InstallSkill_Tip], Source={x:Static svc:Loc.Instance}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Kb" Width="30" Height="30" Background="{DynamicResource ChipFill}" BorderBrush="{StaticResource ChipRim}"
                                                    BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Kb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Kb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Kb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Kb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- 安装 Skill 弹出面板：输入框 + 安装按钮 + 状态行（写法对齐上面的模型列表 Popup） -->
                                <Popup PlacementTarget="{Binding ElementName=SkillBtn}" Placement="Bottom"
                                       VerticalOffset="4" IsOpen="{Binding SkillMenuOpen, Mode=TwoWay}"
                                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#252320" BorderBrush="#3A3631" BorderThickness="1"
                                            CornerRadius="8" Padding="10" Width="300">
                                        <StackPanel>
                                            <TextBlock Text="{Binding [Island_InstallSkill], Source={x:Static svc:Loc.Instance}}"
                                                       Foreground="#FAF9F5" FontSize="12"/>
                                            <TextBox Text="{Binding SkillInstallInput, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True" TextWrapping="Wrap" Height="52"
                                                     Background="#2C2C2E" Foreground="#FAF9F5" BorderBrush="#3A3A3C"
                                                     CaretBrush="#FAF9F5" FontSize="11" Margin="0,6,0,6"/>
                                            <!-- 安装 / 取消 并排：安装中隐藏"安装"显示"取消"（取消触发令牌 + 杀进程树） -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Cursor="Hand" FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                                        Command="{Binding InstallSkillCommand}"
                                                        Visibility="{Binding IsSkillInstalling, Converter={StaticResource InvBoolToVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Gb" Background="#252320" BorderBrush="#3A3631"
                                                                    BorderThickness="1" CornerRadius="8" Padding="12,5">
                                                                <TextBlock Text="{Binding [Island_InstallSkill_Go], Source={x:Static svc:Loc.Instance}}"
                                                                           Foreground="#FAF9F5" FontSize="12" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Gb" Property="BorderBrush" Value="#CC785C"/>
                                                                    <Setter TargetName="Gb" Property="Background" Value="#2F2C28"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <!-- 取消：仅安装中可见（CanExecute 亦受 IsSkillInstalling 约束） -->
                                                <Button Cursor="Hand" FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                                        Command="{Binding CancelSkillInstallCommand}"
                                                        Visibility="{Binding IsSkillInstalling, Converter={StaticResource BoolToVis}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Cxb" Background="#252320" BorderBrush="#3A3631"
                                                                    BorderThickness="1" CornerRadius="8" Padding="12,5">
                                                                <TextBlock Text="{Binding SkillCancelLabel}"
                                                                           Foreground="#FAF9F5" FontSize="12" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Cxb" Property="BorderBrush" Value="#CC785C"/>
                                                                    <Setter TargetName="Cxb" Property="Background" Value="#2F2C28"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock Text="{Binding SkillInstallStatus}" Foreground="#9AA0A6"
                                                       FontSize="11" TextWrapping="Wrap" MaxWidth="280" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <!-- 会话来源筛选：三态循环 全部(▦)→仅终端(⌨)→仅客户端(🖥)。
                                     依据 ClaudeMetadata.Entrypoint 区分终端 / Claude Desktop 会话。 -->
                                <Button x:Name="SrcFilterBtn" Cursor="Hand" Margin="6,0,0,0"
                                        FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                        Command="{Binding CycleSourceFilterCommand}"
                                        ToolTip="{Binding SourceFilterTip}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Fb" Width="30" Height="30" Background="{DynamicResource ChipFill}" BorderBrush="{StaticResource ChipRim}"
                                                    BorderThickness="1.3" CornerRadius="15">
                                                <TextBlock x:Name="FbIco" Text="&#xE71D;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Fb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Fb" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                                <!-- 1=仅终端：命令行字形；高亮边框提示"筛选生效中" -->
                                                <DataTrigger Binding="{Binding SourceFilter}" Value="1">
                                                    <Setter TargetName="FbIco" Property="Text" Value="&#xE756;"/>
                                                    <Setter TargetName="Fb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                </DataTrigger>
                                                <!-- 2=仅客户端：显示器字形 -->
                                                <DataTrigger Binding="{Binding SourceFilter}" Value="2">
                                                    <Setter TargetName="FbIco" Property="Text" Value="&#xE7F4;"/>
                                                    <Setter TargetName="Fb" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 检查更新：点开"发现新版"小面板；有新版时按钮右上角亮一颗小红点 -->
                                <ToggleButton x:Name="UpdateBtn" Cursor="Hand" Margin="6,0,0,0"
                                              FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                              IsChecked="{Binding UpdateMenuOpen, Mode=TwoWay}"
                                              ToolTip="{Binding [Island_CheckUpdate_Tip], Source={x:Static svc:Loc.Instance}}"
                                              Command="{Binding CheckUpdateCommand}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid>
                                                <Border x:Name="Ub" Width="30" Height="30" Background="{DynamicResource ChipFill}" BorderBrush="{StaticResource ChipRim}"
                                                        BorderThickness="1.3" CornerRadius="15">
                                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets"
                                                               Foreground="#FFFFFF" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- 小红点：仅有新版时可见，提示有更新可装 -->
                                                <Ellipse Width="7" Height="7" Fill="#FF5252"
                                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                                         Margin="0,-2,-2,0"
                                                         Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ub" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Ub" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Ub" Property="BorderBrush" Value="{StaticResource ChipRim}"/>
                                                    <Setter TargetName="Ub" Property="Background" Value="{DynamicResource ChipHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- "发现新版"弹出面板：版本标题 + 可滚动更新日志 + 立即更新/稍后 + 下载进度（写法对齐安装 Skill 面板） -->
                                <Popup PlacementTarget="{Binding ElementName=UpdateBtn}" Placement="Bottom"
                                       VerticalOffset="4" IsOpen="{Binding UpdateMenuOpen, Mode=TwoWay}"
                                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#252320" BorderBrush="#3A3631" BorderThickness="1"
                                            CornerRadius="8" Padding="10" Width="300">
                                        <StackPanel>
                                            <!-- 标题：发现新版本 v{LatestVersion}；无新版时隐藏，只显示状态行 -->
                                            <TextBlock Text="{Binding LatestVersion, StringFormat={}发现新版本 v{0}}"
                                                       Foreground="#FAF9F5" FontSize="13" FontWeight="SemiBold"
                                                       Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"/>
                                            <!-- 更新日志：可滚动（日志可能较长），固定最大高度 -->
                                            <ScrollViewer MaxHeight="120" Margin="0,6,0,0"
                                                          VerticalScrollBarVisibility="Auto"
                                                          Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding UpdateNotes}" Foreground="#C8C8C8"
                                                           FontSize="11" TextWrapping="Wrap"/>
                                            </ScrollViewer>
                                            <!-- 立即更新 / 稍后 并排：仅有新版时显示 -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0"
                                                        Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                                                <Button Cursor="Hand" FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                                        Command="{Binding InstallUpdateCommand}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Uib" Background="#252320" BorderBrush="#3A3631"
                                                                    BorderThickness="1" CornerRadius="8" Padding="12,5">
                                                                <TextBlock Text="{Binding [Update_Install], Source={x:Static svc:Loc.Instance}}"
                                                                           Foreground="#FAF9F5" FontSize="12" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Uib" Property="BorderBrush" Value="#CC785C"/>
                                                                    <Setter TargetName="Uib" Property="Background" Value="#2F2C28"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Cursor="Hand" FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                                        Margin="8,0,0,0" Command="{Binding DismissUpdateCommand}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Ulb" Background="#252320" BorderBrush="#3A3631"
                                                                    BorderThickness="1" CornerRadius="8" Padding="12,5">
                                                                <TextBlock Text="{Binding [Update_Later], Source={x:Static svc:Loc.Instance}}"
                                                                           Foreground="#9AA0A6" FontSize="12" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Ulb" Property="BorderBrush" Value="#CC785C"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <!-- 下载进度条：仅下载/安装中显示 -->
                                            <ProgressBar Height="4" Minimum="0" Maximum="1"
                                                         Value="{Binding UpdateProgress}"
                                                         Background="#26FFFFFF" Foreground="#CC785C"
                                                         BorderThickness="0" Margin="0,8,0,0"
                                                         Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                                            <!-- 状态行：检查中 / 已是最新 / 下载中 xx% / 失败 -->
                                            <TextBlock Text="{Binding UpdateStatus}" Foreground="#9AA0A6"
                                                       FontSize="11" TextWrapping="Wrap" MaxWidth="280" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{Binding GlobalModelStatus}"
                                           Foreground="#777777" FontSize="10" VerticalAlignment="Center"
                                           Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>

                        <!-- ── 5 小时余额行：Claude 订阅 5h 滚动窗口剩余额度 ──
                             订阅模式：5h + 余额条 + 余 73% + 重置 2h13m
                             API  模式：API · 1.24M tokens（无进度条/重置）
                             数据来自 /api/oauth/usage（= /usage 同源，零 message 配额）。
                             配色/间距对齐上方媒体行（#111111 / CornerRadius 10 / Margin 8,0,8,2）。 -->
                        <Border Background="{DynamicResource CardFill}"
                                CornerRadius="10"
                                Margin="8,0,8,2"
                                Padding="10,8"
                                Cursor="Hand"
                                ToolTip="{Binding [Island_UsageToggle_Tip], Source={x:Static svc:Loc.Instance}}">
                            <Border.InputBindings>
                                <!-- 点余额行：在"5h 余额"与"最近七天 token 柱状图"之间切换（落盘，下次启动恢复）。 -->
                                <MouseBinding Gesture="LeftClick" Command="{Binding ToggleUsageViewCommand}"/>
                            </Border.InputBindings>
                            <Border.Resources>
                                <!-- 扁平进度条：无边框、圆角细条，Foreground 绑 PlanBarColor，
                                     轨道 #26FFFFFF，高度 6。无 code-behind，纯模板实现 -->
                                <Style x:Key="PlanBar" TargetType="ProgressBar">
                                    <Setter Property="Minimum" Value="0"/>
                                    <Setter Property="Maximum" Value="1"/>
                                    <Setter Property="Height" Value="6"/>
                                    <Setter Property="Foreground"
                                            Value="{Binding PlanBarColor, Converter={StaticResource StrToBrush}}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Border CornerRadius="3"
                                                        Background="#26FFFFFF"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Border x:Name="PART_Track"/>
                                                        <Border x:Name="PART_Indicator"
                                                                HorizontalAlignment="Left"
                                                                CornerRadius="3"
                                                                Background="{TemplateBinding Foreground}"/>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <Grid>
                            <!-- ① 余额视图（默认）：5h 进度条 + 余额% + 重置；ShowUsageChart=true 时隐藏 -->
                            <Grid Visibility="{Binding ShowUsageChart, Converter={StaticResource InvBoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左：Plan / API 标签（灰，跟 CPU/RAM 同字号同色） -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding PlanLabel}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>

                                <!-- Plan 模式组：进度条 + 百分比 + 重置 -->
                                <Grid Grid.Column="1"
                                      Visibility="{Binding PlanIsApi, Converter={StaticResource InvBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ProgressBar Grid.Column="0"
                                                 Style="{StaticResource PlanBar}"
                                                 Value="{Binding PlanBarFraction}"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,10,0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlanPercentText}"
                                               Foreground="#E0E0E0"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               FontFamily="Consolas, Cascadia Code, Segoe UI"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding PlanResetText}"
                                               Foreground="#7C8A9A"
                                               FontSize="10"
                                               FontFamily="Consolas, Cascadia Code, Segoe UI"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"/>

                                    <!-- 刷新按钮：点击立即重新探一次真实余额 + 重置时间 -->
                                    <Button Grid.Column="3" Cursor="Hand" Margin="8,0,0,0"
                                            FocusVisualStyle="{x:Null}" local:Anim.PressScale="True"
                                            Command="{Binding RefreshUsageCommand}"
                                            ToolTip="{Binding [Island_Refresh_Tip], Source={x:Static svc:Loc.Instance}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Rb" Background="Transparent" CornerRadius="5" Padding="4,2">
                                                    <TextBlock x:Name="Ico" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="11" Foreground="#9AA0A6" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Rb" Property="Background" Value="#2F2C28"/>
                                                        <Setter TargetName="Ico" Property="Foreground" Value="#CC785C"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsRefreshingUsage}" Value="True">
                                                        <Setter TargetName="Ico" Property="Foreground" Value="#CC785C"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- API 模式组：· 1.24M tokens（替代进度条组） -->
                                <TextBlock Grid.Column="1"
                                           Visibility="{Binding PlanIsApi, Converter={StaticResource BoolToVis}}"
                                           Foreground="#E0E0E0"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center">
                                    <Run Text="·" Foreground="#7C8A9A"/>
                                    <Run Text="{Binding PlanValueText}"/>
                                </TextBlock>
                            </Grid>

                            <!-- ② 七天 token 柱状图视图：ShowUsageChart=true 时显示，再次点击切回余额。
                                 柱子用量越多绿色越深；右侧只显示七天总量数字。 -->
                            <Grid Visibility="{Binding ShowUsageChart, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="7天" Foreground="#9AA0A6" FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ItemsControl Grid.Column="1" ItemsSource="{Binding UsageBars}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="12" Height="24" Margin="0,0,3,0"
                                                    Background="Transparent" ToolTip="{Binding Tooltip}">
                                                <Border VerticalAlignment="Bottom" Height="{Binding BarHeight}"
                                                        CornerRadius="2"
                                                        Background="{Binding Color, Converter={StaticResource StrToBrush}}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Grid.Column="2" Text="{Binding UsageTotalText}" Foreground="#7CC47F"
                                           FontSize="11" FontWeight="SemiBold"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                            </Grid>
                        </Border>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="350">
                            <ItemsControl ItemsSource="{Binding Sessions}" Margin="8,6,8,2">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource CardFill}"
                                                CornerRadius="12"
                                                Padding="12,10"
                                                Margin="0,2"
                                                Cursor="Hand"
                                                local:Anim.Entrance="True">
                                            <Border.InputBindings>
                                                <MouseBinding Gesture="LeftClick"
                                                              Command="{Binding JumpCommand}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 状态圆点：网页同步开启时可点击 —— 把该会话置顶同步到网页
                                                     （置顶时橙色外圈，再点取消）。同步关闭时按钮禁用、点击穿透
                                                     到卡片本身的跳转。 -->
                                                <Button Grid.Column="0" Margin="1,0,11,0" VerticalAlignment="Center"
                                                        Command="{Binding SyncWebCommand}" Cursor="Hand"
                                                        FocusVisualStyle="{x:Null}"
                                                        IsEnabled="{Binding DataContext.WebSyncOn, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        ToolTip="{Binding [Island_DotSync_Tip], Source={x:Static svc:Loc.Instance}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid Background="Transparent" Width="16" Height="16">
                                                                <Ellipse Width="16" Height="16"
                                                                         Stroke="#CC785C" StrokeThickness="1.5"
                                                                         Visibility="{Binding IsWebFeatured, Converter={StaticResource BoolToVis}}"/>
                                                                <Ellipse Width="12" Height="12"
                                                                         local:Anim.FillColor="{Binding StatusColorValue}"
                                                                         local:Anim.Pulse="{Binding IsAttentionPhase}"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <!-- 显示态标题（用户改过名就显示自定义名） -->
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="#DDDDDD"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="200"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsEditingTitle, Converter={StaticResource InvBoolToVis}}"/>
                                                    <!-- 编辑态：内联改名输入框。Enter 保存 / Esc 取消 / 失焦保存（见 code-behind） -->
                                                    <TextBox Text="{Binding EditableTitle, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsEditingTitle, Converter={StaticResource BoolToVis}}"
                                                             MinWidth="120" MaxWidth="200"
                                                             Background="#2A2A2A" Foreground="#FFFFFF"
                                                             BorderBrush="#CC785C" BorderThickness="1"
                                                             CaretBrush="#FFFFFF" FontSize="12" Padding="4,1"
                                                             VerticalAlignment="Center"
                                                             IsVisibleChanged="RenameBox_IsVisibleChanged"
                                                             KeyDown="RenameBox_KeyDown"
                                                             LostKeyboardFocus="RenameBox_LostFocus"/>
                                                    <TextBlock Text="{Binding Elapsed}"
                                                               Foreground="#484848"
                                                               FontSize="11"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsEditingTitle, Converter={StaticResource InvBoolToVis}}"/>
                                                    <!-- Running 时的"思考中"3 点脉冲（AI-Native 风），Idle/完成自动隐藏不耗 CPU -->
                                                    <local:TypingDots VerticalAlignment="Center" Margin="8,0,0,0"
                                                                      Visibility="{Binding IsRunningPhase, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>

                                                <!-- 卡片右侧操作区：3 个权限模式切换图标按钮 + 原小叉号。
                                                     模式按钮均为 icon-only（无文字标签），hover 提示英文；
                                                     视觉与叉号一致（20x20 / CornerRadius 10 / hover #2A2A2A）。
                                                     全是 Button —— 跟叉号一样自己吃掉点击，不触发卡片 JumpCommand。
                                                     注意：Claude Code 切权限模式靠终端 Shift+Tab 轮询，没有
                                                     幂等的"设为模式 X"按键，所以这三个按钮是尽力而为
                                                     (best-effort)：每次点发一次 Shift+Tab 循环一格，不保证
                                                     精确落到目标模式（详见 SessionManager.SendModeSwitchAsync）。
                                                     Row of 3 permission-mode toggles + the original ✕. Mode
                                                     buttons are icon-only; English tooltip on hover. Delivery is
                                                     best-effort (Claude Code cycles modes via Shift+Tab; no
                                                     idempotent set-mode key) — see SendModeSwitchAsync. -->
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center">
                                                    <StackPanel.Resources>
                                                        <!-- 共用：20x20 圆角图标按钮模板（叉号同款 hover） -->
                                                        <Style x:Key="CardIconBtn" TargetType="Button">
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="local:Anim.PressScale" Value="True"/>
                                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                                            <Setter Property="Margin" Value="2,0,0,0"/>
                                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="IBd"
                                                                                Width="20" Height="20"
                                                                                CornerRadius="10"
                                                                                Background="Transparent">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="IBd" Property="Background" Value="#2A2A2A"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="IBd" Property="Background" Value="#3A3A3A"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </StackPanel.Resources>

                                                    <!-- 重命名（E70F = 铅笔字形）：点击进入内联编辑，改完 Enter 保存。
                                                         自定义名按会话 id 持久化到 settings.json，下次启动仍记得。
                                                         （原 accept edits / auto / plan 三个模式按钮已按需求移除。） -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding RenameCommand}"
                                                            ToolTip="重命名 / Rename">
                                                        <TextBlock Text="&#xE70F;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11"
                                                                   Foreground="#5A5A5A"/>
                                                    </Button>

                                                    <!-- 图钉：固定该会话，"清理任务"不会把它清掉（E718 = Pin 字形）。
                                                         快捷回复（评论图标 + 输入框）暂时取消，后续更新再加入。 -->
                                                    <Button Style="{StaticResource CardIconBtn}"
                                                            Command="{Binding TogglePinCommand}"
                                                            ToolTip="{Binding [Island_Pin_Tip], Source={x:Static svc:Loc.Instance}}">
                                                        <TextBlock Text="&#xE718;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#5A5A5A"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                            <Setter Property="Foreground" Value="#CC785C"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>

                                                    <!-- 小叉号：临时把这条 session 从灵动岛收起，
                                                         再次活动时自动放回。Button 自己吃掉点击，
                                                         不会触发卡片的 JumpCommand。（保持原样，放最后） -->
                                                    <Button Command="{Binding DismissCommand}"
                                                            VerticalAlignment="Center"
                                                            Margin="6,0,0,0"
                                                            Cursor="Hand"
                                                            ToolTip="{Binding [Island_Dismiss_Tip], Source={x:Static svc:Loc.Instance}}">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="XBd"
                                                                        Width="20" Height="20"
                                                                        CornerRadius="10"
                                                                        Background="Transparent">
                                                                    <TextBlock Text="✕"
                                                                               FontSize="11"
                                                                               Foreground="#5A5A5A"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="XBd" Property="Background" Value="#2A2A2A"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="XBd" Property="Background" Value="#3A3A3A"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </StackPanel>

                                                <!-- 快捷回复输入行（F1）：暂时取消（功能未完善，后续更新再加入）。
                                                     整行折叠 + 不再绑 RevealOpen，避免被展开。代码保留，删掉 Visibility 即恢复。 -->
                                                <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0"
                                                        Visibility="Collapsed">
                                                    <StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid Grid.Column="0">
                                                                <TextBox Text="{Binding QuickReplyInput, UpdateSourceTrigger=PropertyChanged}"
                                                                         Background="#0D0D0D" Foreground="#DDDDDD"
                                                                         BorderBrush="#2A2A2A" BorderThickness="1"
                                                                         CaretBrush="#DDDDDD" FontSize="11"
                                                                         Padding="6,3" VerticalContentAlignment="Center"
                                                                         MaxLines="3" TextWrapping="Wrap" AcceptsReturn="False">
                                                                    <TextBox.InputBindings>
                                                                        <KeyBinding Key="Enter" Command="{Binding SendQuickReplyCommand}"/>
                                                                    </TextBox.InputBindings>
                                                                </TextBox>
                                                                <TextBlock Text="{Binding [Island_Reply_Placeholder], Source={x:Static svc:Loc.Instance}}" Foreground="#555555" FontSize="11"
                                                                           Margin="8,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding QuickReplyInput}" Value="">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Grid>
                                                            <Button Grid.Column="1" Command="{Binding SendQuickReplyCommand}"
                                                                    Margin="6,0,0,0" Cursor="Hand" ToolTip="{Binding [Island_Send_Tip], Source={x:Static svc:Loc.Instance}}"
                                                                    FocusVisualStyle="{x:Null}" local:Anim.PressScale="True">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="SBd" Width="26" Height="24" CornerRadius="6"
                                                                                Background="Transparent">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="SBd" Property="Background" Value="#2A2A2A"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="SBd" Property="Background" Value="#3A3A3A"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                                                           FontSize="12" Foreground="#0A84FF"/>
                                                            </Button>
                                                        </Grid>
                                                        <TextBlock Text="{Binding QuickReplyStatus}" Foreground="#777777" FontSize="10" Margin="2,3,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding QuickReplyStatus}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding QuickReplyStatus}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- 权限模式：参考 Apple 风 Permission Request 卡片设计 ——
                         上 = 信息区（橙点 + 标题 + 工具 tag + 入参 monospace 块）
                         下 = 选项区（3 键竖排，仅两种配色：白底深字 = 主，深底浅字 = 次）
                         Visibility 必须挂在没有 DataContext 重写的外层 ContentControl 上。 -->
                    <ContentControl Visibility="{Binding IsPermissionMode, Converter={StaticResource BoolToVis}}">
                    <Border DataContext="{Binding PermissionSession}"
                            Background="{DynamicResource PanelFill}"
                            CornerRadius="14"
                            Padding="20,16"
                            Margin="10,8,10,10">
                        <StackPanel>
                            <!-- 信息区头：橙点 + "Permission Request" 标头 + 时间戳 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Ellipse Width="9" Height="9"
                                         VerticalAlignment="Center"
                                         Margin="0,0,9,0"
                                         Fill="#FF9F0A"/>
                                <TextBlock Text="Permission Request"
                                           Foreground="#F2F2F7"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#6C6C70"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="280"/>
                                <TextBlock Text="{Binding Elapsed}"
                                           Foreground="#48484A"
                                           FontSize="11"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                                <!-- 并发待批准徽标：并行 subagent 同会话有多个权限请求时，提示还排队着几个 -->
                                <Border Visibility="{Binding HasMultiplePending, Converter={StaticResource BoolToVis}}"
                                        Background="#3A2A12" CornerRadius="6" Padding="7,2"
                                        Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PendingPermissionBadge}"
                                               Foreground="#FFCC8A" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>

                            <!-- ===========================================================
                                 三条分支互斥，均绑在 PermissionSession 这个 DataContext 上：
                                  · IsPlanReview=true  → ExitPlanMode 计划审阅：完整渲染
                                    PlanMarkdown（见下方独立分支），不显示这里的原始入参块 /
                                    Allow-Deny / AskUserQuestion 选项。
                                  · IsPlanReview=false 时，走下面这个容器，内部再按 IsQuestion
                                    二选一：
                                    - IsQuestion=false → 普通工具权限：Allow once / (Always) /
                                      Deny，文案按 entrypoint 走（行为 100% 不变）。
                                    - IsQuestion=true  → AskUserQuestion：每个候选答案一个
                                      按钮（"{Number}. {Label}"，description 作副文案 + ToolTip），
                                      竖排可滚，末尾一个 Skip。点击 → AnswerQuestionCommand
                                      (CommandParameter=Number) / SkipQuestionCommand。
                                 =========================================================== -->

                            <StackPanel Visibility="{Binding IsPlanReview, Converter={StaticResource InvBoolToVis}}">
                                <!-- Tool tag + headline：⚠ 工具 + 关键参数 -->
                                <TextBlock Text="{Binding PermissionHeadline}"
                                           Foreground="#FFCC8A"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>

                                <!-- 入参展开块：monospace + 微深底，像参考图里的 diff/code 预览。
                                     HasCodeReviewDiff=false 时显示——包括非 Edit/MultiEdit/Write
                                     的普通工具，也包括 diff 构建失败的兜底（这两个块必须互斥绑
                                     同一个属性，不能各自绑 IsCodeReview 的正反面：diff 构建失败
                                     时 IsCodeReview 仍是 true，若这块绑 IsCodeReview 的反面就会
                                     两块都不显示，卡片变成空白，用户看不到任何信息）。 -->
                                <Border Visibility="{Binding HasCodeReviewDiff, Converter={StaticResource InvBoolToVis}}"
                                        Background="{DynamicResource CodeFill}"
                                        CornerRadius="8"
                                        Padding="12,10"
                                        Margin="0,0,0,14">
                                    <TextBlock Text="{Binding PermissionFullDetail}"
                                               Foreground="#B5B5BA"
                                               FontSize="11"
                                               FontFamily="Consolas, Cascadia Code, Menlo"
                                               TextWrapping="Wrap"
                                               MaxHeight="160"/>
                                </Border>

                                <!-- ===================================================
                                     代码审阅 diff 块（IsCodeReview=true 时显示，即
                                     Edit/MultiEdit/Write 三个工具）：红底删除行/绿底新增行/
                                     普通上下文行 + 行号，对齐 GitHub PR diff 观感。
                                     CodeReviewDiff 由 DiffBuilder 从 tool_input 构建
                                     （见该类注释），批准/拒绝仍走下面同一套 Allow once/
                                     Always/Deny 按钮组，这个功能只换"详情怎么展示"。
                                     =================================================== -->
                                <StackPanel Visibility="{Binding HasCodeReviewDiff, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,0,14">
                                    <TextBlock Text="{Binding CodeReviewHeaderText}"
                                               Foreground="#B5B5BA"
                                               FontSize="11"
                                               FontFamily="Consolas, Cascadia Code, Menlo"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>

                                    <Border Background="{DynamicResource CodeFill}"
                                            CornerRadius="8"
                                            Padding="0,8">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      MaxHeight="280">
                                            <ItemsControl ItemsSource="{Binding CodeReviewDiff.Hunks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- 每个 hunk（连续改动区块）之间留一点间距，
                                                             视觉上跟相邻 hunk 区分开 -->
                                                        <ItemsControl ItemsSource="{Binding Lines}" Margin="0,0,0,6">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Padding="12,1">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Added">
                                                                                        <Setter Property="Background" Value="#1E3A24"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="Removed">
                                                                                        <Setter Property="Background" Value="#3A1E22"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="30"/>
                                                                                <ColumnDefinition Width="30"/>
                                                                                <ColumnDefinition Width="14"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0"
                                                                                       Text="{Binding OldLineNumber}"
                                                                                       Foreground="#5C5C60"
                                                                                       FontSize="10"
                                                                                       FontFamily="Consolas, Cascadia Code, Menlo"
                                                                                       HorizontalAlignment="Right"
                                                                                       Margin="0,0,6,0"/>
                                                                            <TextBlock Grid.Column="1"
                                                                                       Text="{Binding NewLineNumber}"
                                                                                       Foreground="#5C5C60"
                                                                                       FontSize="10"
                                                                                       FontFamily="Consolas, Cascadia Code, Menlo"
                                                                                       HorizontalAlignment="Right"
                                                                                       Margin="0,0,6,0"/>
                                                                            <TextBlock Grid.Column="2"
                                                                                       FontSize="11"
                                                                                       FontFamily="Consolas, Cascadia Code, Menlo">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Text" Value=""/>
                                                                                        <Setter Property="Foreground" Value="#5C5C60"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Kind}" Value="Added">
                                                                                                <Setter Property="Text" Value="+"/>
                                                                                                <Setter Property="Foreground" Value="#5FD076"/>
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding Kind}" Value="Removed">
                                                                                                <Setter Property="Text" Value="−"/>
                                                                                                <Setter Property="Foreground" Value="#F07178"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                            <TextBlock Grid.Column="3"
                                                                                       Text="{Binding Text}"
                                                                                       FontSize="11"
                                                                                       FontFamily="Consolas, Cascadia Code, Menlo"
                                                                                       TextWrapping="Wrap">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Foreground" Value="#B5B5BA"/>
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Kind}" Value="Added">
                                                                                                <Setter Property="Foreground" Value="#C9F0CE"/>
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding Kind}" Value="Removed">
                                                                                                <Setter Property="Foreground" Value="#F0C9CC"/>
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- 截断提示：只有 CodeReviewTruncatedText 非空（即真的截断了）才显示 -->
                                    <TextBlock Text="{Binding CodeReviewTruncatedText}"
                                               Foreground="#6C6C70"
                                               FontSize="10.5"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CodeReviewTruncatedText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 普通权限按钮组（IsQuestion=false 时显示） -->
                                <StackPanel Visibility="{Binding IsQuestion, Converter={StaticResource InvBoolToVis}}">
                                    <Button Content="{Binding YesButtonLabel}"
                                            Command="{Binding RespondYesCommand}"
                                            Style="{StaticResource AppleButtonPrimary}"
                                            Margin="0,0,0,7"/>
                                    <Button Content="{Binding AlwaysButtonLabel}"
                                            Command="{Binding RespondAlwaysCommand}"
                                            Visibility="{Binding ShowAlwaysButton, Converter={StaticResource BoolToVis}}"
                                            Style="{StaticResource AppleButtonPrimary}"
                                            Margin="0,0,0,7"/>
                                    <Button Content="{Binding NoButtonLabel}"
                                            Command="{Binding RespondNoCommand}"
                                            Style="{StaticResource AppleButtonSecondary}"/>
                                </StackPanel>

                                <!-- AskUserQuestion 选项按钮组（IsQuestion=true 时显示） -->
                                <StackPanel Visibility="{Binding IsQuestion, Converter={StaticResource BoolToVis}}">
                                    <!-- 多问题进度指示（IsMultiQuestion=true 时显示，如"问题 2/4"）。
                                         单问题场景为空字符串 + 隐藏，不占布局空间。 -->
                                    <TextBlock Text="{Binding QuestionProgressText}"
                                               FontSize="11"
                                               Foreground="#9AA0A6"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"
                                               TextAlignment="Left"
                                               Visibility="{Binding IsMultiQuestion, Converter={StaticResource BoolToVis}}"/>
                                    <!-- 选项可能较多 —— 限高滚动（复用全局扁平 ScrollBar 样式） -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="260">
                                        <ItemsControl ItemsSource="{Binding QuestionOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <!-- 整行一个按钮：主行 "{Number}. {Label}" +
                                                         description 小字副行；description 同时挂
                                                         ToolTip（长描述行内省略后仍可悬停看全文）。
                                                         复用 Apple 主按钮观感（白底深字 + 圆角 9）。 -->
                                                    <Button Command="{Binding DataContext.AnswerQuestionCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding Number}"
                                                            Style="{StaticResource AppleButtonPrimary}"
                                                            HorizontalContentAlignment="Left"
                                                            Margin="0,0,0,7"
                                                            ToolTip="{Binding Description}">
                                                        <StackPanel>
                                                            <TextBlock FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#1C1C1E"
                                                                       TextWrapping="Wrap">
                                                                <Run Text="{Binding Number, Mode=OneWay}"/><Run Text=". "/><Run Text="{Binding Label, Mode=OneWay}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Foreground="#6C6C70"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,3,0,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <!-- 没 description 就整行折叠，不留空白 -->
                                                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Skip：跳过该问题（深底浅字次按钮，与 Deny 同观感） -->
                                    <Button Content="Skip"
                                            Command="{Binding SkipQuestionCommand}"
                                            Style="{StaticResource AppleButtonSecondary}"
                                            Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- ===========================================================
                                 ExitPlanMode 计划审阅分支（IsPlanReview=true 时显示）：
                                 完整渲染 PlanMarkdown（标题/列表/代码块/粗体等正确显示），
                                 而不是走上面的原始 JSON 详情块 / Allow-Deny / AskUserQuestion。
                                 三个按钮文案照抄 Claude Code 终端 ExitPlanMode 提示原文，
                                 Command/CommandParameter 先绑定占位名字，由下一步接上真正实现：
                                   RespondPlanCommand(int 1/2/3) — 对应三个按钮。
                                   PlanFeedbackText / SendPlanFeedbackCommand — 反馈输入框。
                                 =========================================================== -->
                            <StackPanel Visibility="{Binding IsPlanReview, Converter={StaticResource BoolToVis}}">
                                <!-- Markdown 渲染区：MaxHeight 限高防止纵向撑爆岛体，MarkdownScrollViewer
                                     自带滚动（内部就是 FlowDocumentScrollViewer），不用再套一层 ScrollViewer。
                                     深色主题适配见上方 Window.Resources 里 PlanMd* 系列 Style 的注释。 -->
                                <Border Background="{DynamicResource CodeFill}"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,0,0,14">
                                    <mdxaml:MarkdownScrollViewer x:Name="PlanMarkdownViewer"
                                                                  Markdown="{Binding PlanMarkdown}"
                                                                  MaxHeight="420"
                                                                  Background="Transparent"
                                                                  Foreground="#E5E5EA"
                                                                  IsToolBarVisible="False"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled">
                                        <mdxaml:MarkdownScrollViewer.Engine>
                                            <mdxaml:Markdown DocumentStyle="{StaticResource PlanMdDocumentStyle}"
                                                             Heading1Style="{StaticResource PlanMdH1Style}"
                                                             Heading2Style="{StaticResource PlanMdH2Style}"
                                                             Heading3Style="{StaticResource PlanMdH3Style}"
                                                             Heading4Style="{StaticResource PlanMdH4Style}"
                                                             Heading5Style="{StaticResource PlanMdH5Style}"
                                                             Heading6Style="{StaticResource PlanMdH6Style}"/>
                                        </mdxaml:MarkdownScrollViewer.Engine>
                                    </mdxaml:MarkdownScrollViewer>
                                </Border>

                                <!-- 选项按钮：按宿主动态镜像（PlanOptions 按 entrypoint 生成）——
                                     CLI = 终端的 "1./2./3." 编号菜单；Claude Desktop = Electron
                                     弹窗的真实按钮 Accept / Accept and auto mode / Reject / Revise…
                                     （用户实测截图确认的文案）。Key 透传给 RespondToPlanAsync 分流。 -->
                                <ItemsControl ItemsSource="{Binding PlanOptions}" Margin="0,0,0,3">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Label}"
                                                    Command="{Binding DataContext.RespondPlanCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Key}"
                                                    Style="{StaticResource AppleButtonPrimary}"
                                                    Margin="0,0,0,7"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 反馈输入框：多行、深色底浅字，占位提示文字叠一层浅灰 TextBlock
                                     （同 QuickReplyInput 那套"按内容是否为空控制显隐"写法）。
                                     Text 绑 PlanFeedbackText，下一步接上 VM 里的同名属性。 -->
                                <Grid Margin="0,0,0,7">
                                    <TextBox Text="{Binding PlanFeedbackText, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Background="{DynamicResource CodeFill}"
                                             Foreground="#F2F2F7"
                                             CaretBrush="#F2F2F7"
                                             BorderThickness="0"
                                             FontSize="12"
                                             Padding="10,8"
                                             MinHeight="56"
                                             MaxHeight="120"
                                             VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="对这份计划有想法？写点反馈…"
                                               Foreground="#6C6C70"
                                               FontSize="12"
                                               Margin="12,10,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PlanFeedbackText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PlanFeedbackText}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- 发送反馈：下一步接上 VM 里的 SendPlanFeedbackCommand -->
                                <Button Content="发送反馈"
                                        Command="{Binding SendPlanFeedbackCommand}"
                                        Style="{StaticResource AppleButtonSecondary}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding PermissionHintText}"
                                       Foreground="#48484A"
                                       FontSize="10"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    </ContentControl>

                </StackPanel>

            </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
